# Example environment configuration.
# This file is not loaded automatically by the app; use it as a reference
# for variables you must set in your shell, process manager (PM2, Docker, etc.),
# or hosting provider configuration (Heroku config vars, Azure App Settings, etc.).
# Do NOT commit a real .env file with secrets to version control.

# Node environment; use 'development' for local runs.
# Set to 'production' only in live deployments.
NODE_ENV=development

# Port the server listens on (default: 3000)
PORT=3000

# Set to '1' when running behind a reverse proxy (e.g. Azure App Service, nginx, Heroku)
# in production so express-rate-limit can identify clients correctly via X-Forwarded-For.
# Leave unset or set to '0' for local development where you are not behind a proxy.
TRUST_PROXY=0

# Copy this file to .env and fill in the values for your environment.
# Run `npm run setup` to install dependencies, then `npm start` to launch the server.

# Set to 'production' in live deployments (enables trust proxy automatically)
NODE_ENV=production

# Port the server listens on (default: 3000)
PORT=3000

# Set to '1' when running behind a reverse proxy (e.g. Azure App Service, nginx, Heroku).
# Required for express-rate-limit to identify clients correctly via X-Forwarded-For.
# Not needed when NODE_ENV=production is already set.
TRUST_PROXY=1
